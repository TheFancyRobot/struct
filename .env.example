# Database
DATABASE_URL=postgres://struct:struct@localhost:5432/struct

# Artifact storage (dev FS adapter)
ARTIFACT_STORAGE_ROOT=./.local/artifacts
MAX_TEXT_SOURCE_BYTES=1048576

# Worker ingestion polling
WORKER_POLL_INTERVAL_MS=1000
WORKER_JOB_STALE_MS=300000

# DuckDB sandbox
DUCKDB_SANDBOX_ROOT=./.local/duckdb-sandbox
DATA_ENGINE_URL=http://127.0.0.1:4300
DATA_ENGINE_TOKEN=replace-with-at-least-16-characters

# Ports
API_PORT=3001
WEB_PORT=3000
WORKER_METRICS_PORT=3002

# Optional OTLP trace export; stdout tracing remains enabled without a collector.
# OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:4318/v1/traces

# Fred / Model providers (add actual keys for model-dependent paths)
FRED_PROVIDER_PACKAGE=@fancyrobot/fred-openai
FRED_MODEL=gpt-4.1-mini
RESEARCH_MAX_ELAPSED_MS=60000
OPENAI_API_KEY=replace-me
# FRED_ANTHROPIC_API_KEY=sk-ant-...
