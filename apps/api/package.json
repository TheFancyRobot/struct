{
  "name": "@struct/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/main.ts",
  "types": "./src/main.ts",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run",
    "migrations:up": "tsx src/migrations/run.ts --direction up",
    "migrations:down": "tsx src/migrations/run.ts --direction down"
  },
  "dependencies": {
    "effect": "3.22.0",
    "@struct/domain": "workspace:*",
    "@struct/persistence": "workspace:*",
    "@struct/observability": "workspace:*"
  },
  "devDependencies": {
    "typescript": "7.0.2",
    "tsx": "4.23.1"
  }
}
