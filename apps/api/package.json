{
  "name": "@struct/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/main.ts",
  "types": "./src/main.ts",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "build": "rm -rf dist && bun --bun tsc --project tsconfig.json",
    "typecheck": "bun --bun tsc --noEmit --project tsconfig.json",
    "test": "bun test --max-concurrency 1 .",
    "migrations:up": "bun src/migrations/run.ts --direction up",
    "migrations:down": "bun src/migrations/run.ts --direction down"
  },
  "dependencies": {
    "@struct/domain": "workspace:*",
    "@struct/data-engine": "workspace:*",
    "@struct/observability": "workspace:*",
    "@struct/persistence": "workspace:*",
    "@struct/research-engine": "workspace:*",
    "@struct/retrieval": "workspace:*",
    "@struct/source-storage": "workspace:*",
    "effect": "3.22.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@fancyrobot/fred": "2.0.0",
    "@struct/evaluation": "workspace:*",
    "@struct/fred-workflows": "workspace:*",
    "@struct/ingestion": "workspace:*",
    "typescript": "7.0.2"
  }
}
