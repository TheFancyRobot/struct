{
  "name": "@struct/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/main.ts",
  "types": "./src/main.ts",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "build": "rm -rf dist && tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run --root ../.. apps/api",
    "migrations:up": "tsx src/migrations/run.ts --direction up",
    "migrations:down": "tsx src/migrations/run.ts --direction down"
  },
  "dependencies": {
    "@struct/domain": "workspace:*",
    "@struct/observability": "workspace:*",
    "@struct/persistence": "workspace:*",
    "@struct/research-engine": "workspace:*",
    "@struct/retrieval": "workspace:*",
    "@struct/source-storage": "workspace:*",
    "effect": "3.22.0",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@struct/ingestion": "workspace:*",
    "typescript": "7.0.2",
    "tsx": "4.23.1"
  }
}
