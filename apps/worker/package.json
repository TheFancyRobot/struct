{
  "name": "@struct/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/main.ts",
  "types": "./src/main.ts",
  "scripts": {
    "dev": "bun --watch src/main.ts",
    "build": "rm -rf dist && bun --bun tsc --project tsconfig.json",
