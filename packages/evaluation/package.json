{
  "name": "@struct/evaluation",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "corpus:generate": "bun src/corpus-generate.ts",
    "corpus:compare-hashes": "bun src/corpus-compare-hashes.ts",
    "corpus:smoke": "bun src/phase-02-smoke.ts && bun src/corpus-generator-smoke.ts",
    "corpus:eval": "bun src/corpus-eval.ts",
    "directory:eval": "bun src/directory-refresh-smoke.ts",
    "bench": "bun src/benchmarks/run.ts",
    "typecheck": "bun --bun tsc --noEmit --project tsconfig.json",
    "test": "bun test --max-concurrency 1 --pass-with-no-tests ."
  },
  "dependencies": {
    "@struct/domain": "workspace:*",
    "@struct/fred-workflows": "workspace:*",
    "@struct/ingestion": "workspace:*",
    "@struct/research-engine": "workspace:*",
    "@struct/retrieval": "workspace:*",
    "effect": "3.22.0"
  },
  "devDependencies": {
    "typescript": "7.0.2"
  }
}
